# Copy to .env and fill in. Do not commit .env to git.
# Gmail: use the shop account and create an App Password at
# https://myaccount.google.com/apppasswords (2-Step Verification must be on).

BCN_EMAIL_APP_PASSWORD=your-16-char-app-password
# Optional: if sending from a different address (defaults to bcn.shop24@gmail.com)
# BCN_EMAIL_FROM=bcn.shop24@gmail.com

# For static export (GitHub Pages): custom order form needs a backend.
# Create a free form at https://formspree.io, set the notification email to
# bcn.shop24@gmail.com, then run:
#   STATIC_EXPORT_FORM_URL=https://formspree.io/f/YOUR_FORM_ID python manage.py export_static
# STATIC_EXPORT_FORM_URL=https://formspree.io/f/xxxxxxxx

# Optional: run in debug mode (Django)
# DEBUG=1

# Optional: database path (default: db.sqlite3 in project root)
# DATABASE_PATH=/path/to/db.sqlite3
